# Dune API key — same one used in signal-pipeline
DUNE_API_KEY=your_dune_api_key_here

# Saved query ID from dune.com (see dune_query.sql)
# 1. Go to dune.com/queries/new
# 2. Paste dune_query.sql, run it, save it
# 3. Copy the ID from the URL: dune.com/queries/XXXXXXX
# 4. Set it here
DUNE_QUERY_ID=0
